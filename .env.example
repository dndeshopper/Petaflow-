# PetalFlow — Environment Variables
# Copy to .env.local for local dev; add the same keys in Vercel → Settings → Environment Variables

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
INTERNAL_API_KEY=generate-a-long-random-string

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://kyibybuilncctvbazikx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
SUPABASE_PREVIEW_BUCKET=petal-previews

# Single-user mode — local dev only (omit on Vercel production)
# PETALFLOW_DEFAULT_USER_ID=

# Local only — do NOT add to Vercel
# SUPABASE_DB_PASSWORD=only-for-npm-run-setup-supabase

# AI (optional)
AI_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
